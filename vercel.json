{
    "buildCommand": "cd frontend && npm install && chmod +x node_modules/.bin/react-scripts && PUBLIC_URL=/ CI=false npm run build",
    "outputDirectory": "frontend/build",
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/static/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}